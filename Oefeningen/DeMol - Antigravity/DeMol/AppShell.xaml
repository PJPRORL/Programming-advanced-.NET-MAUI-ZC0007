<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DeMol.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Views="clr-namespace:DeMol.Views"
    FlyoutBehavior="Flyout"
    Title="DeMol">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate Views:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        Title="ControlePage"
        ContentTemplate="{DataTemplate Views:ControlePage}"
        Route="Controlepage" />
    
    <ShellContent
        Title="VraagPage"
        ContentTemplate="{DataTemplate Views:VraagPage}"
        Route="Vraagpage" />

</Shell>
