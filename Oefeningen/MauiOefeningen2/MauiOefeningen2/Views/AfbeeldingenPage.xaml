<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiOefeningen2.Views.AfbeeldingenPage"
             Title="Afbeeldingen">
    <VerticalStackLayout>
        <Label 
            Text="Afbeeldingen"
            FontSize="25"
            FontAttributes="Bold"
            HorizontalTextAlignment="Start"
            VerticalTextAlignment="Start"
            HorizontalOptions="Start"
            Margin="10,10,0,0"/>
        <HorizontalStackLayout Margin="10,10,0,0">
            <Label 
                Text="Selecteer een getal:"
                HorizontalOptions="Start"
                VerticalOptions="Center"
                Margin="0,0,10,0"/>
            <Label
                Text="getal"
                Margin="0,0,5,0"
                VerticalOptions="Center"
                FontSize="18"
                WidthRequest="30"
                HorizontalTextAlignment="Center"/>
            <Stepper 
                Minimum="1" 
                Maximum="5" 
                Increment="1"/>
        </HorizontalStackLayout>
        <Button
            WidthRequest="250"
            Margin="10,20,0,0"
            Text="Afbeelding tonen"
            VerticalOptions="Start"
            HorizontalOptions="Start"
            BackgroundColor="#6366f1"
            TextColor="White"
            CornerRadius="5"/>
        <Image
            Source="landschap.png"
            HeightRequest="400"
            HorizontalOptions="Fill"
            VerticalOptions="Start"
            Aspect="AspectFill"
            Margin="10,20,10,10"/>
    </VerticalStackLayout>
</ContentPage>