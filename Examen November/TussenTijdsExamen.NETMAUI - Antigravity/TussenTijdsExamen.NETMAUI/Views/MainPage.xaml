<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:TussenTijdsExamen.NETMAUI.ViewModels"
             x:Class="TussenTijdsExamen.NETMAUI.Views.MainPage"
             xmlns:model="clr-namespace:TussenTijdsExamen.NETMAUI.Models"
             x:DataType="viewmodel:MainViewModel"
             Title="{Binding Title}">

    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*,*,*">

        <CollectionView Grid.Column="0" Grid.RowSpan="5" 
                        ItemsSource="{Binding Docenten}" 
                        SelectedItem="{Binding Docent}" 
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Docent">
                    <VerticalStackLayout Padding="10">
                        <Label Text="Namen:" TextColor="Gray" FontSize="10"/>
                        <Label Text="{Binding VolledigeNaam}"
                               FontAttributes="Bold"
                               FontSize="Medium"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView Grid.Column="1" Grid.RowSpan="5"
                        ItemsSource="{Binding Leerlingen}" 
                        SelectedItem="{Binding Leerling}" 
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Leerling">
                     <VerticalStackLayout Padding="10">
                        <Label Text="{Binding VolledigeNaam}"
                               FontAttributes="Bold"
                               FontSize="Medium"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid> 
</ContentPage>