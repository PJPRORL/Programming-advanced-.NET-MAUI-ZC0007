<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tussentijdsexamen2025r0615208.Views.HomePage"
             Title="HomePage">
    
    <VerticalStackLayout>
        <CollectionView ItemsSource="{Binding Docenten}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding }" FontSize="16"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Label 
            x:Name="Docenten"
            Text="Docenten:"
            VerticalOptions="Start"
            FontSize="12"/>
        <Entry 
            x:Name="DocentenEntry"
            Text="{Binding }"/>
    </VerticalStackLayout>
</ContentPage>