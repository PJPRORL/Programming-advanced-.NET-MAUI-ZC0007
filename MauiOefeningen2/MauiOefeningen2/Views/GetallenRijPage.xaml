<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MauiOefeningen2.ViewModels"
             x:Class="MauiOefeningen2.Views.GetallenRijPage"
             x:DataType="viewmodel:GetallenRijViewModel"
             Title="GetallenRij">
    <VerticalStackLayout>
        <!--<CollectionView ItemsSource="{Binding Getallen}" SelectedItem="{Binding Getal}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="">
                    
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>-->
        <Label 
            Text="GetallenRij"
            FontSize="25"
            FontAttributes="Bold"/>
        <Label 
            Text="Geef een getal in:"/>
        <Entry
            x:Name="GetalEntry"
            Text="{Binding TijdelijkGetal}"
            Placeholder="Getal"
            Keyboard="Numeric"
            WidthRequest="50"/>
        <Button 
            Text="Getal Toevoegen"
            Command="{Binding VoegGetallenToeCommand}"/>
        <Label 
            Text="{Binding Output}"/>
    </VerticalStackLayout>
</ContentPage>