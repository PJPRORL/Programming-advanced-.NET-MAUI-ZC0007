## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# MonoDevelop/Xamarin Studio
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]uild/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Mac / VS for Mac
.DS_Store

# ReSharper / JetBrains
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
packages/

# Project configuration, Property Sheets
*.props
*.targets

# SQLite databases
*.sqlite
*.sqlite3

# MAUI specific app packages
*.aab
*.apk
*.ipa
*.appx
*.msix

# Large Media Files (GitHub limit 100MB)
*.mp4
*.avi
*.mkv
*.mov
*.wmv
